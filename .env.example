# --- APP / ENV ---
APP_ENV=development
LOG_LEVEL=INFO

# --- RATE LIMITING ---
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SECONDS=60

# --- POSTGRES / POSTGIS DATABASE CONFIG ---
POSTGRES_DB=davangere_spatial_db
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://postgres_admin:change_me@db:5432/davangere_spatial_db
POSTGRES_PORT=5433

# --- MINIO OBJECT STORAGE CONFIG ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me
MINIO_ENDPOINT=storage:9000
MINIO_BUCKET_NAME=urban-survey-datasets
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# --- JWT SECURITY CONFIG ---
JWT_SECRET_KEY=change_me_to_a_random_64_char_hex_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LOCAL AI OLLAMA CONFIG ---
OLLAMA_BASE_URL=http://ai_engine:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- FRONTEND CONFIG ---
VITE_API_BASE_URL=http://localhost:8001
VITE_GOOGLE_MAPS_API_KEY=REPLACE_WITH_YOUR_GOOGLE_MAPS_API_KEY
FRONTEND_URL=http://localhost:3000

# 3D Earth mode (globe + terrain + sky). All optional; when unset the app
# falls back to public, token-free AWS Terrarium terrain tiles.
VITE_ENABLE_3D_EARTH=true
VITE_TERRAIN_TILEJSON_URL=
VITE_TERRAIN_TILES_URL=
VITE_TERRAIN_ENCODING=terrarium
VITE_TERRAIN_TILE_SIZE=256
VITE_TERRAIN_MAX_ZOOM=14

# --- SEED USERS ---
ADMIN_EMAIL=admin@davangere.gov.in
ADMIN_PASSWORD=change_me_admin
ARCHITECT_EMAIL=architect@davangere.gov.in
ARCHITECT_PASSWORD=change_me_architect
