# ---- Stage 1: install ----
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

# ---- Stage 2: build ----
FROM node:22-alpine AS build
WORKDIR /app
ENV NODE_ENV=production
ARG VITE_API_BASE_URL
ARG VITE_GOOGLE_MAPS_API_KEY
ARG VITE_ENABLE_3D_EARTH
ARG VITE_TERRAIN_TILEJSON_URL
ARG VITE_TERRAIN_TILES_URL
ARG VITE_TERRAIN_ENCODING
ARG VITE_TERRAIN_TILE_SIZE
ARG VITE_TERRAIN_MAX_ZOOM
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_GOOGLE_MAPS_API_KEY=$VITE_GOOGLE_MAPS_API_KEY
ENV VITE_ENABLE_3D_EARTH=$VITE_ENABLE_3D_EARTH
ENV VITE_TERRAIN_TILEJSON_URL=$VITE_TERRAIN_TILEJSON_URL
ENV VITE_TERRAIN_TILES_URL=$VITE_TERRAIN_TILES_URL
ENV VITE_TERRAIN_ENCODING=$VITE_TERRAIN_ENCODING
ENV VITE_TERRAIN_TILE_SIZE=$VITE_TERRAIN_TILE_SIZE
ENV VITE_TERRAIN_MAX_ZOOM=$VITE_TERRAIN_MAX_ZOOM
COPY --from=deps /app/node_modules /app/node_modules
COPY . /app
RUN npm run build

# ---- Stage 3: production serve ----
FROM node:22-alpine AS production
WORKDIR /app
RUN npm install -g serve
COPY --from=build /app/dist ./dist
EXPOSE 3000
CMD ["serve", "dist", "-s", "-l", "3000"]
