# Backend API base URL used by the Vite dev server proxy and the built frontend.
# Leave empty (or unset) in production when the API is served on the same origin.
VITE_API_BASE_URL=http://localhost:8001
# Browser-restricted Google Maps JavaScript API key (Street View control).
VITE_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# 3D Earth mode (globe + terrain + sky). All values are OPTIONAL.
# When VITE_ENABLE_3D_EARTH is not "false" and no provider is given, the app
# falls back to the public, token-free AWS Terrarium terrain tiles so a real
# 3D elevation view works out of the box. Set VITE_ENABLE_3D_EARTH=false to
# disable 3D Earth entirely.
# ---------------------------------------------------------------------------
VITE_ENABLE_3D_EARTH=true
# Option A — TileJSON endpoint for a raster-dem source:
VITE_TERRAIN_TILEJSON_URL=
# Option B — explicit raster tile URL template (used instead of TileJSON):
VITE_TERRAIN_TILES_URL=
# Encoding MUST match the provider: "terrarium" | "mapbox" | "custom".
VITE_TERRAIN_ENCODING=terrarium
VITE_TERRAIN_TILE_SIZE=256
VITE_TERRAIN_MAX_ZOOM=14

